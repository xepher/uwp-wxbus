<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="unity" type="Microsoft.Practices.Unity.Configuration.UnityConfigurationSection, Microsoft.Practices.Unity.Configuration" />
    <section name="modules" type="Microsoft.Practices.Prism.Modularity.ModulesConfigurationSection, Microsoft.Practices.Prism"/>
  </configSections>
  <unity>
    <container>
      <types>
        <type type="Interface.ICalculator, Interface" mapTo="MainModule.Calculator, MainModule" />
        <type type="Interface.ICalculatorAdd, Interface" mapTo="ModuleA.CalculatorAdd, ModuleA" />
        <type type="Interface.ICalculatorSub, Interface" mapTo="ModuleB.CalculatorSub, ModuleB" />
        <type type="Interface.ICalculatorMul, Interface" mapTo="ModuleC.CalculatorMul, ModuleC" />
        <type type="Interface.ICalculatorDiv, Interface" mapTo="ModuleD.CalculatorDiv, ModuleD" />
      </types>
    </container>
  </unity>
  <modules>
    <module assemblyFile="ModuleA.dll" moduleType="ModuleA.ModuleA, ModuleA, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" moduleName="ModuleA" startupLoaded="false" />
    <!--<module assemblyFile="ModuleB.dll" moduleType="ModuleB.ModuleB, ModuleB, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" moduleName="ModuleB" startupLoaded="false" />
    <module assemblyFile="ModuleC.dll" moduleType="ModuleC.ModuleC, ModuleC, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" moduleName="ModuleC" startupLoaded="false" />
    <module assemblyFile="ModuleD.dll" moduleType="ModuleD.ModuleD, ModuleD, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" moduleName="ModuleD" startupLoaded="false" />-->
    <module assemblyFile="MainModule.dll" moduleType="MainModule.MainModule, MainModule, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" moduleName="MainModule" startupLoaded="false">
      <dependencies>
        <dependency moduleName="ModuleA" />
        <!--<dependency moduleName="ModuleB" />
        <dependency moduleName="ModuleC" />
        <dependency moduleName="ModuleD" />-->
      </dependencies>
    </module>
  </modules>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
</configuration>