<Application 
    x:Class="org.xepher.wuxibus.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"       
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:phone="clr-namespace:Microsoft.Phone.Controls;assembly=Microsoft.Phone"
    xmlns:shell="clr-namespace:Microsoft.Phone.Shell;assembly=Microsoft.Phone"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--Application Resources-->
    <Application.Resources>
        <system:String x:Key="ApplicationTitle">Wuxi Public Transportation Search(WP)</system:String>
        <system:String x:Key="Author">Author : xepher</system:String>

        <system:String x:Key="PageAbout">About</system:String>
        <system:String x:Key="PageMain">Routes</system:String>
        <system:String x:Key="PageStations">Route</system:String>
        
        <system:String x:Key="LoadingText">Loading...</system:String>
    </Application.Resources>

    <Application.ApplicationLifetimeObjects>
        <!--Required object that handles lifetime events for the application-->
        <shell:PhoneApplicationService 
            Launching="Application_Launching" Closing="Application_Closing" 
            Activated="Application_Activated" Deactivated="Application_Deactivated"/>
    </Application.ApplicationLifetimeObjects>

</Application>