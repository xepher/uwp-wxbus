<UserControl x:Class="org.xepher.control.UC_BusInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    d:DesignHeight="160" d:DesignWidth="480">
    
    <Grid x:Name="LayoutRoot">
        <TextBlock x:Name="txtBusID" Margin="10,10,0,0" HorizontalAlignment="Left" Text="BusID: " VerticalAlignment="Top" FontSize="26.667" />
        <TextBlock x:Name="txtStation" Margin="10,60,0,60" TextWrapping="Wrap" Text="Station: " FontSize="26.667" HorizontalAlignment="Left"/>
        <TextBlock x:Name="txtTime" HorizontalAlignment="Left" Margin="10,0,0,10" TextWrapping="Wrap" Text="Time: " VerticalAlignment="Bottom" FontSize="26.667"/>
        <TextBlock x:Name="txtTTL" Margin="240,10,0,0" TextWrapping="Wrap" Text="TTL: " VerticalAlignment="Top" d:LayoutOverrides="Width" FontSize="26.667" HorizontalAlignment="Left"/>
    </Grid>
</UserControl>
