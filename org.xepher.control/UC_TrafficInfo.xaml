<UserControl x:Class="org.xepher.control.UC_TrafficInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource CustomFontFamilyNormal}"
    FontSize="{StaticResource CustomFontSizeNormal}"
    Foreground="{StaticResource CustomForegroundBrush}"
    d:DesignHeight="480" d:DesignWidth="480">
    
    <Grid x:Name="LayoutRoot" Background="#FF80B8DB" Margin="0,1,0,0">
        <Border Width="10" Background="#FF009BE3" HorizontalAlignment="Left" Margin="5,2.5,0,2.5"/>
        <TextBlock x:Name="txtTrafficInfo" Margin="17,5,0,5" FontSize="32" Width="463" />
    </Grid>
</UserControl>
